<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Queries - Admin Dashboard</title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
<div class="overlay" id="overlay"></div>

<%- include('partials/header') %>

<div class="container">
    <%- include('partials/sidebar') %>

    <main class="main-content">
        <div class="page-header">
            <h1>Farmer Queries</h1>
            <p>Total: <%= queries.length %> issue reports raised by farmers.</p>
        </div>

        <div class="section">
            <div class="table-container">
                <table>
                    <thead>
                    <tr>
                        <th>#</th>
                        <th>Farmer</th>
                        <th>Crop</th>
                        <th>Field Worker</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Resolved Note</th>
                        <th>Raised</th>
                    </tr>
                    </thead>
                    <tbody>
                    <% queries.forEach((query, index) => { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td>
                                <strong><%= query.farmerId?.name || 'N/A' %></strong><br>
                                <span class="text-muted"><%= query.farmerId?.mobile || query.farmerId?.village || 'N/A' %></span>
                            </td>
                            <td><%= query.cropId?.cropName || 'N/A' %></td>
                            <td><%= query.fieldworkerId?.name || 'N/A' %></td>
                            <td><%= query.description %></td>
                            <td>
                                <span class="badge <%= query.status === 'RESOLVED' ? 'badge-success' : 'badge-warning' %>">
                                    <%= query.status %>
                                </span>
                            </td>
                            <td><%= query.resolutionNote || 'Pending' %></td>
                            <td><%= new Date(query.createdAt).toLocaleString() %></td>
                        </tr>
                    <% }); %>
                    <% if (queries.length === 0) { %>
                        <tr>
                            <td colspan="8" class="empty-state">No queries found</td>
                        </tr>
                    <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<script src="/js/dashboard.js"></script>
</body>
</html>

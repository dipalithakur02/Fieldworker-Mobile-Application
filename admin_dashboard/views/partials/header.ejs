<header class="header">
  <div class="header-content">
    <button
      type="button"
      class="hamburger"
      id="hamburger"
      aria-label="Toggle navigation"
      aria-controls="sidebar"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="logo">
      <img src="/images/app-icon.png" alt="Farmer Crop App" class="brand-icon">
      <div class="logo-copy">
        <span class="logo-title">Farmer Crop Admin</span>
        <span class="logo-subtitle">System monitoring</span>
      </div>
    </div>
    <div class="header-actions">
      <span class="user-name">Admin: <%= user.name %></span>
      <a href="/logout" class="btn-logout">Logout</a>
    </div>
  </div>
</header>
